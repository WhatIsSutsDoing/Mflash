{code:"List.Sum({10, 20, 30})", ask:"What does this return?", answer:"60", example:'Table.Group(..., {{"Total", each List.Sum([Sales])}}) uses this inside an aggregation.', breakdown:["{10,20,30} is the input list.","List.Sum adds every item together.","Final result: 60."]},
{code:"List.Select({1,2,3,4}, each _ > 2)", ask:"What does this return?", answer:"{3, 4}", example:"The list equivalent of Table.SelectRows, for filtering plain lists.", breakdown:["Each item in {1,2,3,4} is checked against the condition _ > 2.","1 and 2 fail the check; 3 and 4 pass.","Final result: {3, 4}."]},
{code:"List.Transform({1,2,3}, each _ * 10)", ask:"What does this return?", answer:"{10, 20, 30}", example:"M's 'map' — apply a calculation to every item in a list at once.", breakdown:["Each item in {1,2,3} is multiplied by 10 in turn.","1 becomes 10, 2 becomes 20, 3 becomes 30.","Final result: {10, 20, 30}."]},
{code:'List.Contains({"A","B","C"}, "B")', ask:"What does this return?", answer:"true", example:"Table.SelectRows(t, each List.Contains(ValidCodes, [Code])) filters against an allow-list.", breakdown:['The list {"A","B","C"} is scanned for a match.','"B" is found among the items.',"Final result: true."]},
{code:"List.Distinct({1,1,2,2,3})", ask:"What does this return?", answer:"{1, 2, 3}", example:"A quick way to get unique values without building a whole table.", breakdown:["The list {1,1,2,2,3} is scanned in order.","Repeated values are collapsed, keeping only the first occurrence.","Final result: {1, 2, 3}."]},
{code:'Record.Field([Name="Ana", Age=30], "Age")', ask:"What does this return?", answer:"30", example:"Useful when the field name you want is stored in a variable, not hardcoded.", breakdown:['The record [Name="Ana",Age=30] is the input.','Record.Field looks up the field named "Age" by that text name.',"Final result: 30."]},
{code:'Record.FieldNames([Name="Ana", Age=30])', ask:"What does this return?", answer:'{"Name", "Age"}', example:"Handy for dynamically checking which fields exist before referencing them.", breakdown:["The record has two fields defined: Name and Age.","Record.FieldNames reads off just their names, not their values.",'Final result: {"Name", "Age"}.']},
{code:'Record.ToTable([Name="Ana", Age=30])', ask:"What does this return?", answer:"A 2-column table listing each field name and its value.", example:"Great for quickly inspecting an unfamiliar record's shape.", breakdown:["The record's fields are Name and Age.","Record.ToTable converts each field into its own row.","Each row gets a Name column (the field's name) and a Value column (its value).",'Final result: a 2-row table listing Name/"Ana" and Age/30.']},
{code:"let Square = (x) => x * x in Square", ask:"What is Square here?", answer:"A reusable custom function.", example:"Once defined, Square(6) anywhere later in the query returns 36.", breakdown:["Square is defined as a function taking one parameter.","in Square returns that function value directly, uncalled.","Final result: a reusable function, ready to be invoked later as Square(...)."]},
{code:"let Add = (x, y) => x + y in Add(3, 4)", ask:"What does this query return?", answer:"7", example:"Custom functions pay off most when the same calculation repeats across many steps.", breakdown:["Add is defined as a two-parameter function.","Add(3,4) calls it with x=3 and y=4.","The body computes 3 + 4.","Final result: 7."]},
]},
{ id:10, key:"Advanced", title:"Advanced M", subtitle:"folding, #shared, @, types", cards:[
{code:'Table.SelectRows(\n  Sql.Database("srv","db"){[Schema="dbo",Item="Orders"]}[Data],\n  each [Amount] > 100\n)', ask:"Why is this likely fast even on a huge table?", answer:"Because the filter can 'fold' back into a SQL WHERE clause at the source.", example:"Query folding lets SQL Server do the filtering instead of Power Query.", breakdown:["Sql.Database(...) connects to the SQL source and exposes its tables.","[Data] retrieves the Orders table as an M table value.","Table.SelectRows adds a filter condition on top of that table.","Because the source is a database, M translates the filter into SQL and lets the server apply it.","Final result: only matching rows are returned, filtered efficiently at the source."]},
{code:"Table.Buffer(Source)", ask:"What does this do, and what's the tradeoff?", answer:"Loads Source fully into memory now; this breaks query folding for steps after it.", example:"Used when you need a stable snapshot, e.g. before a step that reads Source more than once.", breakdown:["Source would normally be evaluated lazily, step by step, possibly against a live connection.","Table.Buffer forces the entire table to be read into memory right now.","Any steps built on this buffered copy no longer fold back to the original source.","Final result: a fixed, in-memory snapshot of Source."]},
{code:"#shared", ask:"What does this return?", answer:"A record listing every built-in and custom function/query currently in scope.", example:"Type #shared into a blank query to browse the whole function library.", breakdown:["#shared has no arguments — it reads the current evaluation environment.","It gathers every built-in function together with any custom queries defined in the file.","Final result: one large record mapping names to all of those function/query values."]},
{code:"let Fact = (n) => if n = 0 then 1 else n * @Fact(n-1) in Fact(5)", ask:"What does this return, and what does @ do?", answer:"120 — the @ lets the function call itself recursively.", example:"Without @, Fact can't reliably resolve its own name from inside its own body.", breakdown:["Fact(5) checks if n=0: false, so it computes 5 * @Fact(4).","@Fact(4) checks n=0: false, computes 4 * @Fact(3).","This continues down to @Fact(0), which returns 1 since n=0 is true.","The results multiply back up: 1×1×2×3×4×5.","Final result: 120."]},
{code:"let A = 1/0, B = 5 in B", ask:"Does this query error?", answer:"No — A is never evaluated, since only B is returned.", example:"This is lazy evaluation: unused steps are never actually computed.", breakdown:["M evaluates lazily — steps are only computed when something needs their value.","in B only asks for B's value, never A's.","Since nothing references A, the 1/0 error inside it is never triggered.","Final result: 5, with no error raised."]},
{code:"Table.Schema(Source)", ask:"What does this return?", answer:"A table describing each column's name, type, and other metadata.", example:"Great for debugging why a TransformColumnTypes step isn't behaving as expected.", breakdown:["Source is the table being inspected.","Table.Schema reads structural metadata rather than the row data itself.","It reports each column's name, data type, and other properties.","Final result: a table describing Source's structure, one row per column."]},
{code:'Error.Record("Validation", "Negative amount", [Amount])', ask:"What is this building?", answer:"A structured error object with a reason, message, and detail.", example:'More useful for debugging than a bare error "message" string.', breakdown:['"Validation" is stored as the error\'s reason.','"Negative amount" is stored as the human-readable message.',"[Amount] is attached as additional detail for debugging.","Final result: a structured error value, ready to be raised with the 'error' keyword."]},
{code:"type table [Amount = number, Name = text]", ask:"What is this?", answer:"A type declaration describing a table's expected column names and types.", example:"Often used to ascribe a precise return type on a custom function.", breakdown:["type table starts a table type declaration.","Amount is declared to require the number type.","Name is declared to require the text type.","Final result: a type value describing the expected shape of a table, not actual data."]},
{code:"Value.Type(5)", ask:"What does this return?", answer:"The type value 'number'.", example:"Useful inside a custom function to branch behavior based on an argument's type.", breakdown:["5 is evaluated first as a plain number.","Value.Type inspects that value and reports its type rather than its value.","Final result: the type value 'number'."]},
{code:"Function.Invoke(Add, {3, 4})   // Add = (x,y) => x+y", ask:"What does this do?", answer:"Calls Add with arguments 3 and 4, returning 7.", example:"Useful when the number or order of arguments is only known at runtime.", breakdown:["Add is the function value being called.","{3,4} supplies its arguments as a list instead of writing Add(3,4) directly.","Function.Invoke matches list items to parameters in order: x=3, y=4.","The body computes 3+4.","Final result: 7."]},
]},
];

let screen = "levels";
let levelIdx = 0;
let order = [];
let pos = 0;
let flipped = false;
const known = {};

function shuffle(arr) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function progressFor(lvl) { return known[lvl.id] ? known[lvl.id].size : 0; }

const levelListEl = document.getElementById("level-list");
function renderLevels() {
  levelListEl.innerHTML = "";
  LEVELS.forEach((lvl, i) => {
    const p = progressFor(lvl);
    const total = lvl.cards.length;
    const num = String(lvl.id).padStart(2, "0");
    const btn = document.createElement("button");
    btn.className = "level-btn";
    btn.innerHTML = `
      <span class="lhs">
        <span class="muted">Level${num}_${lvl.key}</span>
        <span class="muted"> = </span>
        <span class="str">"${lvl.title}"</span><span class="muted">,</span>
      </span>
      <span class="rhs">
        <span style="font-size:12px;color:${p === total ? 'var(--success)' : 'var(--muted)'}">${p}/${total}</span>
        <span class="dot ${p === total ? 'done' : p > 0 ? 'some' : ''}"></span>
      </span>`;
    btn.addEventListener("click", () => enterLevel(i));
    levelListEl.appendChild(btn);
  });
}

const levelsScreenEl = document.getElementById("levels-screen");
const cardScreenEl = document.getElementById("card-screen");
const lvlNameEl = document.getElementById("lvl-name");
const lvlPosEl = document.getElementById("lvl-pos");
const progressFillEl = document.getElementById("progress-fill");
const flipCardEl = document.getElementById("flip-card");
const cardCodeEl = document.getElementById("card-code");
const cardAskEl = document.getElementById("card-ask");
const cardAnswerEl = document.getElementById("card-answer");
const cardExampleEl = document.getElementById("card-example");
const cardBreakdownEl = document.getElementById("card-breakdown");

function currentCard() {
  const lvl = LEVELS[levelIdx];
  const realIdx = order[pos];
  return lvl.cards[realIdx];
}

function renderCard() {
  const lvl = LEVELS[levelIdx];
  const card = currentCard();
  lvlNameEl.textContent = lvl.title;
  lvlPosEl.textContent = `${pos + 1} / ${order.length}`;
  progressFillEl.style.width = `${((pos + 1) / order.length) * 100}%`;
  cardCodeEl.textContent = card.code;
  cardAskEl.textContent = card.ask;
  cardAnswerEl.textContent = card.answer;
  cardExampleEl.textContent = card.example;
  cardBreakdownEl.innerHTML = "";
  card.breakdown.forEach((step) => {
    const li = document.createElement("li");
    li.textContent = step;
    cardBreakdownEl.appendChild(li);
  });
  flipCardEl.classList.toggle("flipped", flipped);
}

function enterLevel(idx) {
  levelIdx = idx;
  order = shuffle([...Array(LEVELS[idx].cards.length).keys()]);
  pos = 0;
  flipped = false;
  screen = "cards";
  levelsScreenEl.style.display = "none";
  cardScreenEl.style.display = "flex";
  renderCard();
}

function backToLevels() {
  screen = "levels";
  cardScreenEl.style.display = "none";
  levelsScreenEl.style.display = "block";
  renderLevels();
}

function reshuffle() {
  order = shuffle(order);
  pos = 0;
  flipped = false;
  renderCard();
}

function goNext() {
  flipped = false;
  pos = (pos + 1) % order.length;
  renderCard();
}
function goPrev() {
  flipped = false;
  pos = (pos - 1 + order.length) % order.length;
  renderCard();
}

function setMastery(isKnown) {
  const lvl = LEVELS[levelIdx];
  const realIdx = order[pos];
  if (!known[lvl.id]) known[lvl.id] = new Set();
  if (isKnown) known[lvl.id].add(realIdx);
  else known[lvl.id].delete(realIdx);
  goNext();
}

document.getElementById("flip-zone").addEventListener("click", (e) => {
  if (e.target.closest(".face")) {
    flipped = !flipped;
    flipCardEl.classList.toggle("flipped", flipped);
  }
});
document.getElementById("back-btn").addEventListener("click", backToLevels);
document.getElementById("shuffle-btn").addEventListener("click", reshuffle);
document.getElementById("prev-btn").addEventListener("click", goPrev);
document.getElementById("next-btn").addEventListener("click", goNext);
document.getElementById("review-btn").addEventListener("click", () => setMastery(false));
document.getElementById("know-btn").addEventListener("click", () => setMastery(true));

document.addEventListener("keydown", (e) => {
  if (screen !== "cards") return;
  if (e.key === "ArrowRight") goNext();
  else if (e.key === "ArrowLeft") goPrev();
  else if (e.key === " " || e.key === "Enter") {
    e.preventDefault();
    flipped = !flipped;
    flipCardEl.classList.toggle("flipped", flipped);
  }
});

renderLevels();
</script>
</body>
</html>
